library
  hs-source-dirs: library
  default-extensions:
    BangPatterns
    DeriveDataTypeable
    DeriveFunctor
    DeriveGeneric
    DeriveTraversable
    FlexibleContexts
    FlexibleInstances
    GeneralizedNewtypeDeriving
    LambdaCase
    NoImplicitPrelude
    OverloadedStrings
    RankNTypes
    ScopedTypeVariables
    StandaloneDeriving
    TypeApplications
    TypeFamilies

  default-language: Haskell2010
  exposed-modules: Hasql.Implicits.Encoders
  other-modules: Hasql.Implicits.Prelude
  build-depends:
    aeson >=1 && <3,
    base >=4.12 && <5,
    bytestring >=0.10 && <1,
    containers >=0.6 && <1,
    hasql >=1.8 && <1.10,
    iproute >=1.7 && <1.8,
    scientific >=0.2 && <1,
    text >=1 && <3,
    time >=1.4 && <2,
    uuid >=1.3 && <2,
    vector >=0.10 && <1,
